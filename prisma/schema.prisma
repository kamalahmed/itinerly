// itinerly — Prisma schema
// Postgres everywhere. Local dev uses Postgres via docker compose or a brew
// install; Vercel uses Vercel Postgres / Neon / Supabase — all just a
// DATABASE_URL away.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Runtime connection — use the POOLED endpoint in production (Neon's
  // `-pooler` host) so serverless functions don't exhaust connections.
  url       = env("DATABASE_URL")
  // Migrations / introspection — must use the DIRECT (non-pooled) endpoint,
  // since `prisma migrate` can't run over PgBouncer's transaction pooler.
  // We read Neon's integration-managed DATABASE_URL_UNPOOLED so the value is
  // auto-rotated with the pooled URL and never needs manual maintenance.
  // Locally / in CI (no pooler) set it equal to DATABASE_URL.
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Country {
  id       Int       @id @default(autoincrement())
  name     String
  iata2    String    @unique
  airports Airport[]
}

model Airport {
  id        Int     @id @default(autoincrement())
  iata      String  @unique
  name      String
  city      String
  timeZone  String
  lat       Float?
  lon       Float?
  countryId Int
  country   Country @relation(fields: [countryId], references: [id])
}

model Airline {
  id          Int     @id @default(autoincrement())
  iata        String  @unique
  name        String
  countryCode String?
  logo        String?
}

// Used by the "mock" provider to mirror echoflights' seeded-DB approach.
model SeededRoute {
  id                 Int     @id @default(autoincrement())
  originIata         String
  destinationIata    String
  airlineIata        String
  flightNumber       String
  departureTimeLocal String // "08:10"
  // Real arrival clock time + day offset for curated real flights. Null for
  // synthetic rows, which derive arrival from departure + durationMinutes.
  arrivalTimeLocal   String?
  arrivalDayOffset   Int     @default(0)
  durationMinutes    Int
  aircraft           String?
  basePriceUSD       Float

  @@index([originIata, destinationIata])
}

// Caches successful provider searches; keyed by hash(origin+dest+date+cabin+pax).
model SearchCache {
  id         Int      @id @default(autoincrement())
  key        String   @unique
  offersJson String
  createdAt  DateTime @default(now())
}

model Booking {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  pnr           String   @unique
  passengerJson String // JSON: array of { title, fullName, dob, nationality, passportNumber, passportExpiry }
  offerJson     String // snapshot of the FlightOffer at booking time
  status        String // "pending" | "paid_fake" | "issued"
  pdfPath       String?
}
