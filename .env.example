# --- Database -------------------------------------------------------------
# Postgres everywhere. For local dev:
#   - docker compose up -d        (uses the bundled docker-compose.yml), or
#   - brew install postgresql@16 && brew services start postgresql@16
# For prod: Vercel Postgres, Neon, or Supabase all give you a URL like this.
# Replace the placeholders below before running anything.
#
# DATABASE_URL          = runtime connection. In production use the POOLED
#                         endpoint (Neon's "-pooler" host) so serverless
#                         functions don't exhaust connections.
# DATABASE_URL_UNPOOLED = direct (non-pooled) endpoint, used only by
#                         `prisma migrate` / `prisma db push`. The Neon Vercel
#                         integration provides this automatically (and rotates
#                         it). Locally (no pooler) set it equal to DATABASE_URL.
DATABASE_URL="postgresql://<USER>:<PASSWORD>@<HOST>:5432/<DB>?schema=public"
DATABASE_URL_UNPOOLED="postgresql://<USER>:<PASSWORD>@<HOST>:5432/<DB>?schema=public"

# --- Flight data provider -------------------------------------------------
# mock | amadeus | duffel
#
# `mock` (default) = curated REAL data for popular Bangladesh routes +
#   connections, with a synthetic generator covering ANY other origin/
#   destination worldwide (plausible flag carriers, distances → durations).
#   Always returns results; never needs an API key.
#
# REAL-DATA UPGRADE: set FLIGHT_PROVIDER=amadeus and add a free Amadeus
#   Self-Service key below to serve live real flight numbers/times/prices for
#   every route (rate-limited; the 15-min search cache softens the quota).
FLIGHT_PROVIDER=mock

# --- AviationStack (real schedules, easiest free key) ---------------------
# Free key at https://aviationstack.com. When set, the provider chain tries
# AviationStack FIRST (real flight numbers + times for routes it covers, prices
# synthesized) and falls back to the curated+synthetic mock for everything else.
# Free tier is small (HTTP-only, ~100 calls/month) — routes are cached 12h and
# any quota/error degrades gracefully to the mock.
AVIATIONSTACK_API_KEY=

# --- Amadeus Self-Service (real fares too, more setup) --------------------
# Free key at https://developers.amadeus.com — then set FLIGHT_PROVIDER=amadeus.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
# TEST host by default; set to api.amadeus.com to use production.
AMADEUS_HOSTNAME=test.api.amadeus.com

# --- Duffel ---------------------------------------------------------------
DUFFEL_API_KEY=

# --- Rate limiting (Upstash Redis) ---------------------------------------
# Per-IP rate limiting for the search APIs. Leave both blank to disable
# (local dev / CI). Create a free database at https://upstash.com and paste
# the REST URL + token here for production / Vercel.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- App ------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_CURRENCY=USD
