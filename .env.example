# --- Database -------------------------------------------------------------
# Postgres everywhere. For local dev:
#   - docker compose up -d        (uses the bundled docker-compose.yml), or
#   - brew install postgresql@16 && brew services start postgresql@16
# For prod: Vercel Postgres, Neon, or Supabase all give you a URL like this.
# Replace the placeholders below before running anything.
DATABASE_URL="postgresql://<USER>:<PASSWORD>@<HOST>:5432/<DB>?schema=public"

# --- Flight data provider -------------------------------------------------
# mock | amadeus | duffel
# Leave as `mock` to use the default chain: mock → amadeus fallback (when
# Amadeus credentials are set). Set explicitly to force a single provider.
FLIGHT_PROVIDER=mock

# --- Amadeus Self-Service (used as the fallback in the default chain) -----
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
# TEST host by default; set to api.amadeus.com to use production.
AMADEUS_HOSTNAME=test.api.amadeus.com

# --- Duffel ---------------------------------------------------------------
DUFFEL_API_KEY=

# --- Rate limiting (Upstash Redis) ---------------------------------------
# Per-IP rate limiting for the search APIs. Leave both blank to disable
# (local dev / CI). Create a free database at https://upstash.com and paste
# the REST URL + token here for production / Vercel.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- App ------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_CURRENCY=USD
